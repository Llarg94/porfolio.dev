---
import type { AboutContent } from "../i18n/translations"

export interface Props {
  t: AboutContent
}

const { t } = Astro.props
---

<section class="grid md:grid-cols-2 gap-10 items-center max-w-4xl mx-auto animate-on-scroll">
  <div class="relative group">
    <div class="absolute -inset-1 bg-gradient-to-r from-primary-500/20 to-accent-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition duration-300"></div>
    <img
      src="/projects/foto-aboutme.jpg"
      alt="Albert Llargués"
      class="relative rounded-2xl shadow-lg w-full max-w-sm mx-auto object-cover"
    />
  </div>

  <div class="space-y-4">
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{t.p1}</p>
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{t.p2}</p>
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{t.p3}</p>
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{t.p4}</p>

    <div class="flex flex-wrap gap-3 pt-2">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary-50 dark:bg-primary-950/50 text-primary-700 dark:text-primary-300 rounded-full text-sm font-medium">
        <span class="size-1.5 rounded-full bg-primary-500"></span>
        {t.tag1}
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-accent-50 dark:bg-accent-950/50 text-accent-700 dark:text-accent-300 rounded-full text-sm font-medium">
        <span class="size-1.5 rounded-full bg-accent-500"></span>
        {t.tag2}
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-50 dark:bg-green-950/50 text-green-700 dark:text-green-300 rounded-full text-sm font-medium">
        <span class="size-1.5 rounded-full bg-green-500"></span>
        {t.tag3}
      </span>
    </div>
  </div>
</section>
