---
import type { AboutContent } from "../i18n/translations"

export interface Props {
  t: AboutContent
  sectionTitle: string
}

const { t, sectionTitle } = Astro.props

const highlights = [
  { icon: "📍", value: "Barcelona → Trondheim" },
  { icon: "📦", value: "10+ años logística" },
  { icon: "💻", value: "3+ años desarrollo" },
  { icon: "🚀", value: "Full Stack + IA" },
]
---

<section class="max-w-4xl mx-auto">
  <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-start">
    <!-- Image column -->
    <div class="md:col-span-2">
      <div class="relative group animate-on-scroll">
        <div class="absolute -inset-1 bg-gradient-to-r from-primary-500 to-accent-500 rounded-2xl blur-xl opacity-75 group-hover:opacity-100 transition duration-500"></div>
        <div class="absolute -inset-1 bg-gradient-to-r from-primary-500 to-accent-500 rounded-2xl blur-sm group-hover:blur-md transition duration-500"></div>
        <img
          src="/projects/foto-aboutme.jpg"
          alt="Albert Llargués"
          class="relative rounded-2xl shadow-lg w-full object-cover aspect-[3/4]"
        />
        <!-- Floating badge -->
        <div class="absolute -bottom-3 -right-3 bg-white dark:bg-gray-800 rounded-xl px-4 py-2 shadow-lg border border-gray-200 dark:border-gray-700 flex items-center gap-2 animate-fade-in-up">
          <span class="text-lg">👋</span>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Hola!</span>
        </div>
      </div>

      <!-- Quick facts cards -->
      <div class="grid grid-cols-2 gap-3 mt-6 animate-on-scroll">
        {highlights.map((h) => (
          <div class="bg-white dark:bg-gray-900/50 rounded-xl p-3 border border-gray-200/50 dark:border-gray-700/50 text-center hover:shadow-md hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-300">
            <div class="text-lg mb-1">{h.icon}</div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">{h.value}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Content column -->
    <div class="md:col-span-3 space-y-5 animate-on-scroll">
      <!-- Intro heading -->
      <div>
        <span class="text-xs font-semibold text-primary-500 dark:text-primary-400 uppercase tracking-widest">{sectionTitle}</span>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-accent-500">{t.subtitle}</span>
        </h2>
      </div>

      <!-- Paragraphs with staggered animation -->
      <p class="text-gray-600 dark:text-gray-300 leading-relaxed animate-on-scroll">{t.p1}</p>
      <div class="relative pl-6 border-l-2 border-primary-200 dark:border-primary-800 animate-on-scroll">
        <div class="absolute -left-[9px] top-1 size-3.5 rounded-full bg-primary-500 ring-2 ring-white dark:ring-gray-950"></div>
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed italic">
          "{t.p2}"
        </p>
      </div>
      <p class="text-gray-600 dark:text-gray-300 leading-relaxed animate-on-scroll">{t.p3}</p>

      <!-- Highlight quote box -->
      <div class="bg-gradient-to-r from-primary-50 to-accent-50 dark:from-primary-900/20 dark:to-accent-900/20 rounded-xl p-5 border border-primary-200/50 dark:border-primary-800/50 animate-on-scroll">
        <div class="flex gap-3">
          <span class="text-2xl leading-none mt-1">💡</span>
          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
            {t.p4}
          </p>
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 pt-1 animate-on-scroll">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-full text-sm font-medium border border-primary-200/50 dark:border-primary-800/50 hover:bg-primary-100 dark:hover:bg-primary-900/50 transition-colors cursor-default">
          <span class="size-1.5 rounded-full bg-primary-500"></span>
          {t.tag1}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300 rounded-full text-sm font-medium border border-accent-200/50 dark:border-accent-800/50 hover:bg-accent-100 dark:hover:bg-accent-900/50 transition-colors cursor-default">
          <span class="size-1.5 rounded-full bg-accent-500"></span>
          {t.tag2}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full text-sm font-medium border border-green-200/50 dark:border-green-800/50 hover:bg-green-100 dark:hover:bg-green-900/50 transition-colors cursor-default">
          <span class="size-1.5 rounded-full bg-green-500"></span>
          {t.tag3}
        </span>
      </div>
    </div>
  </div>
</section>
