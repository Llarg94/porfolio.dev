---
import ThemeToggle from "./ThemeToggle.astro"
import LanguageSwitcher from "./LanguageSwitcher.astro"
import type { Locale } from "../i18n/translations"
import { translations } from "../i18n/translations"

export interface Props {
  lang?: Locale
}

const { lang = "es" } = Astro.props
const t = translations[lang]
const navItems = t.nav
---

<header
  class="fixed top-0 z-50 flex items-center justify-center w-full mx-auto mt-2 px-4"
>
  <nav
    id="header-nav"
    class="flex items-center gap-1 px-2 py-1.5 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200 bg-white/70 dark:bg-gray-900/70 backdrop-blur-md shadow-sm border border-gray-200/50 dark:border-gray-700/50"
  >
    <div class="hidden md:flex items-center gap-1">
      {
        navItems.map((link) => (
          <a
            class="relative px-3 py-1.5 rounded-full transition-all duration-200 hover:text-primary-500 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-950/50"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition"
      aria-label="Menú de navegación"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <LanguageSwitcher currentLang={lang} />
    <ThemeToggle />
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="fixed top-20 left-4 right-4 md:hidden hidden bg-white/95 dark:bg-gray-900/95 backdrop-blur-md rounded-2xl shadow-xl border border-gray-200/50 dark:border-gray-700/50 p-4"
  >
    <div class="flex flex-col gap-2">
      {
        navItems.map((link) => (
          <a
            class="px-4 py-2.5 rounded-xl transition hover:bg-primary-50 dark:hover:bg-primary-950/50 hover:text-primary-500 dark:hover:text-primary-400"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    // Mobile menu toggle
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });

      // Close on link click
      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
        });
      });

      // Close on outside click
      document.addEventListener("click", (e: MouseEvent) => {
        const target = e.target as Node;
        if (!menuBtn.contains(target) && !mobileMenu.contains(target)) {
          mobileMenu.classList.add("hidden");
        }
      });
    }

    // Active section tracking
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("header nav a[aria-label]");

    const callback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry: IntersectionObserverEntry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const isActive = link.getAttribute("aria-label") === entry.target.id;
            link.classList.toggle("text-primary-500", isActive);
            link.classList.toggle("dark:text-primary-400", isActive);
            if (!isActive) {
              link.classList.remove("text-primary-500", "dark:text-primary-400");
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(callback, {
      rootMargin: "-20% 0px -20% 0px",
      threshold: 0,
    });

    sections.forEach((section) => observer.observe(section));
  });
</script>

<style>
  #header-nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes nav-shadown {
    from {
      @apply bg-white/70 dark:bg-gray-900/70;
    }
    to {
      @apply shadow-lg bg-white/90 dark:bg-gray-900/90;
    }
  }
</style>