---
import ThemeToggle from "./ThemeToggle.astro"
import LanguageSwitcher from "./LanguageSwitcher.astro"
import type { Locale } from "../i18n/translations"
import { translations } from "../i18n/translations"

export interface Props {
  lang?: Locale
}

const { lang = "es" } = Astro.props
const t = translations[lang]
const navItems = t.nav
---

<header
  class="fixed top-0 z-50 flex items-center justify-center w-full mx-auto mt-2 px-4"
>
  <!-- Animated gradient border for the nav -->
  <div class="relative group rounded-full">
    <div class="absolute -inset-[2.5px] rounded-full overflow-hidden opacity-0 group-hover:opacity-100 transition-all duration-500">
      <div class="absolute inset-0 animate-spin-nav"
        style="background: conic-gradient(from 0deg, #a855f7, #d946ef, #3b82f6, #06b6d4, #22d3ee, #3b82f6, #d946ef, #a855f7)">
      </div>
    </div>
    <!-- Glow en hover -->
    <div class="absolute -inset-[5px] rounded-full opacity-0 group-hover:opacity-100 blur-lg transition-all duration-700"
      style="background: conic-gradient(from 0deg, #a855f7, #3b82f6, #06b6d4, #a855f7)">
    </div>
    <nav
      id="header-nav"
      class="relative m-[2.5px] flex items-center gap-1 px-2 py-1.5 text-sm font-medium rounded-full text-gray-200 bg-gray-900/80 dark:bg-black/80 backdrop-blur-xl shadow-lg border border-gray-700/50"
    >
    <div class="hidden md:flex items-center gap-1">
      {
        navItems.map((link) => (
          <a
            aria-label={link.label}
            href={link.url}
            class="nav-link px-3 py-1.5 rounded-full transition-all duration-300 hover:bg-white/10 hover:text-white text-gray-400"
          >
            {link.title}
          </a>
        ))
      }
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden relative p-2 rounded-full hover:bg-white/10 transition"
      aria-label="Menú de navegación"
    >
      <!-- Hamburger icon -->
      <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close icon -->
      <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <LanguageSwitcher currentLang={lang} />
    <ThemeToggle />
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="fixed top-20 left-4 right-4 md:hidden invisible opacity-0 translate-y-2 scale-95 transition-all duration-300 ease-out bg-white/95 dark:bg-gray-900/95 backdrop-blur-md rounded-2xl shadow-xl border border-gray-200/50 dark:border-gray-700/50 p-4"
  >
    <div class="flex flex-col gap-2">
      {
        navItems.map((link) => (
          <a
            class="nav-link px-4 py-2.5 rounded-xl transition hover:bg-primary-50 dark:hover:bg-primary-950/50 hover:text-primary-500 dark:hover:text-primary-400"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>
  </div>
</header>

<style is:global>
  .nav-link.active {
    color: #a855f7;
    background: rgba(168, 85, 247, 0.1);
  }
  .dark .nav-link.active {
    color: #c084fc;
    background: rgba(168, 85, 247, 0.15);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    function openMobile() {
      if (!mobileMenu || !hamburgerIcon || !closeIcon) return;
      mobileMenu.classList.remove("invisible", "opacity-0", "translate-y-2", "scale-95");
      hamburgerIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
    }

    function closeMobile() {
      if (!mobileMenu || !hamburgerIcon || !closeIcon) return;
      mobileMenu.classList.add("invisible", "opacity-0", "translate-y-2", "scale-95");
      hamburgerIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
    }

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener("click", () => {
        const isOpen = !mobileMenu.classList.contains("invisible");
        if (isOpen) {
          closeMobile();
        } else {
          openMobile();
        }
      });

      // Close on link click
      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobile);
      });

      // Close on outside click
      document.addEventListener("click", (e: MouseEvent) => {
        const target = e.target as Node;
        if (!menuBtn.contains(target) && !mobileMenu.contains(target)) {
          closeMobile();
        }
      });
    }

    // Active section tracking — uses .active class
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("header nav a[aria-label]");

    if (sections.length && navLinks.length) {
      const callback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry: IntersectionObserverEntry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              const isActive = link.getAttribute("aria-label") === entry.target.id;
              link.classList.toggle("active", isActive);
            });
          }
        });
      };

      const observer = new IntersectionObserver(callback, {
        rootMargin: "-20% 0px -20% 0px",
        threshold: 0,
      });

      sections.forEach((section) => observer.observe(section));
    }
  });
</script>

<style>
  #header-nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes nav-shadown {
    from {
      background-color: rgba(17, 24, 39, 0.8);
    }
    to {
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
      background-color: rgba(17, 24, 39, 0.95);
    }
  }

  @keyframes spin-nav {
    to { transform: rotate(360deg); }
  }

  .animate-spin-nav {
    animation: spin-nav 3s linear infinite;
  }
</style>