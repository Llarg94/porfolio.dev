---
const AI_PROJECTS = [
  {
    title: "AI Document Analyzer",
    problem: "Reading and extracting insights from long documents is time-consuming.",
    solution: "This app allows users to upload documents and interact with them using AI, enabling fast summarization and contextual Q&A.",
    tech: ["React", "Node.js", "OpenAI API", "Vector DB"],
    features: [
      "Upload and process PDFs",
      "Chat with document context",
      "AI-generated summaries"
    ],
    github: "#",
    link: ""
  }
]
---

<section class="mt-16">
  <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">
    AI Projects
  </h2>

  <div class="grid gap-8">
    {
      AI_PROJECTS.map(project => (
        <article class="p-6 rounded-xl bg-gray-100 dark:bg-gray-900 shadow-md">
          
          <h3 class="text-xl font-semibold">{project.title}</h3>

          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            <strong>Problem:</strong> {project.problem}
          </p>

          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            <strong>Solution:</strong> {project.solution}
          </p>

          <div class="mt-3">
            <strong class="text-sm">Tech:</strong>
            <div class="flex flex-wrap gap-2 mt-1">
              {project.tech.map(t => (
                <span class="text-xs bg-blue-500 text-white px-2 py-1 rounded-full">
                  {t}
                </span>
              ))}
            </div>
          </div>

          <ul class="mt-3 text-sm list-disc list-inside text-gray-700 dark:text-gray-300">
            {project.features.map(f => <li>{f}</li>)}
          </ul>

        </article>
      ))
    }
  </div>
</section>