---
export interface Props {
  t?: string
}

const { t } = Astro.props
const currentYear = new Date().getFullYear()
---

<footer class="mt-32 pb-8">
  <div class="w-full mx-auto container lg:max-w-4xl md:max-w-2xl px-4">
    <div class="border-t border-gray-200 dark:border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <span class="text-sm text-gray-500 dark:text-gray-500">
        © {currentYear} <a href="/" class="hover:text-primary-500 transition-colors">Albert Llargués</a>.
        {t || "Todos los derechos reservados."}
      </span>
      <div class="flex items-center gap-4 text-sm">
        <a href="/#sobre-mi" class="text-gray-500 dark:text-gray-500 hover:text-primary-500 transition-colors">Sobre mí</a>
        <a href="/#proyectos" class="text-gray-500 dark:text-gray-500 hover:text-primary-500 transition-colors">Proyectos</a>
        <a href="/#contacto" class="text-gray-500 dark:text-gray-500 hover:text-primary-500 transition-colors">Contacto</a>
      </div>
    </div>
  </div>
</footer>