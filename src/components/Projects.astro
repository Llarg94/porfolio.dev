---
import type { Translations } from "../i18n/translations"
import GitHub from "../icons/GitHub.astro"

export interface Props {
  t: Translations
  locale: string
}

const { t, locale } = Astro.props

const TAGS_MAP: Record<string, string> = {
  "Node.js": "bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300",
  "HTML": "bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300",
  "CSS": "bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300",
  "JavaScript": "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-300",
  "AWS": "bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300",
  "React": "bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-300",
  "Astro": "bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300",
  "Java": "bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-300",
  "Android": "bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300",
  "Kotlin": "bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300",
  "MySQL": "bg-cyan-100 text-cyan-800 dark:bg-cyan-900/50 dark:text-cyan-300",
  "Supabase": "bg-cyan-100 text-cyan-800 dark:bg-cyan-900/50 dark:text-cyan-300",
  "Tailwind CSS": "bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-300",
  "Vercel": "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300",
  "Python": "bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300",
  "FastAPI": "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300",
  "SQLite": "bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-300",
}

const PROJECTS_META = [
  { emoji: "💳", github: "https://github.com/Llarg94", image: "/projects/e-commerce.png", tags: ["Node.js", "HTML", "CSS", "JavaScript", "MySQL"] },
  { emoji: "💰", github: "https://github.com/Llarg94", image: "/projects/personal-finance.png", tags: ["Python", "FastAPI", "React", "JavaScript", "SQLite"] },
  { emoji: "❤️💙", github: "https://github.com/Llarg94/FCB", image: "/projects/Peña-barcelonista.png", tags: ["Astro", "React", "JavaScript", "Supabase", "Vercel", "Tailwind CSS"] },
  { emoji: "🖥️", github: "https://github.com/Llarg94/PuntualApp", image: "/projects/puntualapp-foto.webp", tags: ["Kotlin", "AWS", "Android", "MySQL"] },
  { emoji: "👾", github: "https://github.com/Llarg94/2Dgame", image: "/projects/videojuego2d.png", tags: ["Java", "Android", "Kotlin"] },
  { emoji: "🏋️", github: "https://github.com/Llarg94", image: "/projects/hyrox-app.jpg", tags: ["React", "Supabase", "Tailwind CSS", "Vercel", "JavaScript"] },
]

const combined = t.projectsList.map((p, i) => ({ ...p, ...PROJECTS_META[i] }))
---

<div class="grid gap-8 animate-on-scroll">
  {
    combined.map(({ image, title, emoji, short, description, tags, github }, index) => (
      <article class="group relative overflow-hidden rounded-2xl bg-white dark:bg-gray-900 border border-gray-200/50 dark:border-gray-700/50 hover:shadow-xl hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-300">
        <div class="grid md:grid-cols-5 gap-0">
          <!-- Image -->
          <div class="md:col-span-2 overflow-hidden">
            <img
              src={image}
              alt={`Captura de ${title}`}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <!-- Content -->
          <div class="md:col-span-3 p-6 flex flex-col justify-between">
            <div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">
                {title} {emoji}
              </h3>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                {short}
              </p>

              <!-- Expandable description -->
              <div class="mt-3">
                <div
                  id={`desc-${index}`}
                  class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed overflow-hidden transition-all duration-300"
                  class:list={{ "max-h-0 opacity-0": true, "max-h-96 opacity-100": false }}
                >
                  <p class="whitespace-pre-line">{description}</p>
                </div>
                <button
                  type="button"
                  id={`btn-desc-${index}`}
                  class="mt-2 text-xs font-medium text-primary-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                  data-show={t.projects.showMore}
                  data-hide={t.projects.showLess}
                  onclick={`
                    const desc = document.getElementById('desc-${index}');
                    const btn = document.getElementById('btn-desc-${index}');
                    const isClosed = desc.classList.contains('max-h-0');
                    desc.classList.toggle('max-h-0');
                    desc.classList.toggle('opacity-0');
                    desc.classList.toggle('max-h-96');
                    desc.classList.toggle('opacity-100');
                    btn.textContent = isClosed ? btn.getAttribute('data-hide') : btn.getAttribute('data-show');
                  `}>
                {t.projects.showMore}
                </button>
              </div>
            </div>

            <div class="mt-4">
              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5">
                {tags.map((tag: string) => (
                  <span class={`inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-full ${TAGS_MAP[tag] || "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300"}`}>
                    {tag}
                  </span>
                ))}
              </div>

              <!-- GitHub link -->
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-primary-500 dark:hover:text-primary-400 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                {t.projects.sourceCode}
              </a>
            </div>
          </div>
        </div>
      </article>
    ))
  }
</div>



