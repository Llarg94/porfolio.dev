---
import type { HeroContent, Locale } from "../i18n/translations"
import Badge from "../components/Badge.astro"
import LinkedInIcon from "../icons/LinkedIn.astro"
import SocialPill from "../components/SocialPill.astro"
import CV from "../icons/CV.astro"
import GitHubIcon from "../icons/GitHub.astro"
import GmailIcon from "../icons/Gmail.astro"

export interface Props {
  t: HeroContent
  lang: Locale
}

const { t, lang } = Astro.props
const personalImageAlt = "Albert Llargués"
const cvUrl = lang === "es" || lang === "ca" ? "/projects/CV%20-%20Albert%20Llargues.pdf" : "/projects/Updated%20CV-Albert%20Llargues.pdf"
---

<div class="max-w-3xl animate-fade-in">
  <div class="flex items-center gap-4 mb-6">
    <div class="relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-primary-500 to-accent-500 rounded-full blur opacity-75 group-hover:opacity-100 transition duration-300"></div>
      <img
        class="relative rounded-full size-20 object-cover"
        src="/projects/albs-foto.webp"
        alt={personalImageAlt}
      />
    </div>
    <a
      href="https://www.linkedin.com/in/albert-llargues"
      target="_blank"
      rel="noopener"
      class="flex items-center transition hover:scale-105"
    >
      <Badge>{t.badge}</Badge>
    </a>
  </div>

  <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white leading-tight">
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-accent-500">
      {t.name}
    </span>
  </h1>

  <div class="mt-4 text-xl sm:text-2xl text-gray-700 dark:text-gray-300">
    <span id="typed-text" data-strings={JSON.stringify(t.typedStrings)}></span>
    <span class="animate-pulse text-primary-500">|</span>
  </div>

  <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl">
    {t.description}
  </p>

  <div class="flex flex-wrap gap-3 mt-8">
    <SocialPill href="https://www.linkedin.com/in/albert-llargues">
      <LinkedInIcon class="size-4 lg:size-5" />
      {t.ctaLinkedin}
    </SocialPill>
    <SocialPill href="https://www.github.com/Llarg94">
      <GitHubIcon class="size-4 lg:size-5" />
      {t.ctaGithub}
    </SocialPill>
    <SocialPill href="mailto:albertllarg1@gmail.com">
      <GmailIcon class="size-4 lg:size-5" />
      {t.ctaEmail}
    </SocialPill>
    <SocialPill href={cvUrl} download>
      <CV class="size-4 lg:size-5" />
      {t.ctaCv}
    </SocialPill>
  </div>

  <div class="mt-12 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-500">
    <span class="relative flex size-2">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
      <span class="relative inline-flex size-2 rounded-full bg-green-500"></span>
    </span>
    {t.available}
  </div>
</div>

<script>
  import TypeIt from "typeit";

  document.addEventListener("astro:page-load", () => {
    const target = document.getElementById("typed-text");
    if (!target) return;

    const strings = JSON.parse(target?.getAttribute("data-strings") || "[]");

    new TypeIt(target, {
      strings,
      speed: 80,
      deleteSpeed: 50,
      loop: true,
      breakLines: false,
      cursor: false,
    }).go();
  });
</script>