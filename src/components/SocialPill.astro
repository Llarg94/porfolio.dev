<span class="group relative inline-flex rounded-full max-w-fit">
  <!-- Animated conic gradient border (solo en hover) -->
  <span class="absolute -inset-[2px] rounded-full overflow-hidden opacity-0 group-hover:opacity-100 transition-all duration-500">
    <span class="absolute inset-0 animate-spin-hover"
      style="background: conic-gradient(from 0deg, #a855f7, #d946ef, #3b82f6, #06b6d4, #22d3ee, #3b82f6, #d946ef, #a855f7)">
    </span>
  </span>
  <!-- Glow en hover -->
  <span class="absolute -inset-[5px] rounded-full opacity-0 group-hover:opacity-100 blur-xl transition-all duration-700"
    style="background: conic-gradient(from 0deg, #a855f7, #3b82f6, #06b6d4, #a855f7)">
  </span>
  <a
    {...Astro.props}
    target="_blank"
    rel="noopener noreferrer"
    role="link"
    class="relative inline-flex items-center justify-center gap-2 px-4 py-1 text-gray-800 transition-all duration-300 bg-gray-100 border border-gray-300 rounded-full dark:bg-gray-800 dark:border-gray-600 dark:text-white focus-visible:ring-yellow-500/80 text-md hover:bg-gray-900 hover:border-transparent hover:text-white dark:hover:bg-gray-100 dark:hover:border-transparent dark:hover:text-black max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:bg-black"
  >
    <slot />
  </a>
</span>

<style>
  @keyframes spin-hover {
    to { transform: rotate(360deg); }
  }

  .animate-spin-hover {
    animation: spin-hover 1.5s linear infinite;
  }
</style>