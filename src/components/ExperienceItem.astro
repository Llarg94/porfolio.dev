---
interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  locale: string
}

const { title, company, description, link, date, locale } = Astro.props

const knowMoreText: Record<string, string> = {
  es: "Saber más",
  ca: "Saber-ne més",
  en: "Learn more",
  no: "Les mer",
}
const knowMore = knowMoreText[locale] || "Learn more"
---
<div
  class="relative pl-8 pb-10 border-l-2 border-gray-200 dark:border-gray-700 last:pb-0 group"
>
  <div class="absolute -left-[9px] top-0 size-4 rounded-full bg-primary-500 ring-4 ring-white dark:ring-gray-950 group-last:bg-primary-400"></div>

  <div class="md:grid md:grid-cols-5 md:gap-8">
    <div class="md:col-span-2 mb-2 md:mb-0">
      <div class="inline-block px-3 py-1 rounded-full bg-primary-50 dark:bg-primary-900/20 border border-primary-200/50 dark:border-primary-800/50 mb-2">
        <time class="text-xs font-semibold text-primary-600 dark:text-primary-400 uppercase tracking-wider">{date}</time>
      </div>
      <h3 class="mt-2 text-xl font-bold text-gray-900 dark:text-white">{title}</h3>
      <p class="text-sm font-medium text-gray-500 dark:text-gray-400">{company}</p>
    </div>
    <div class="md:col-span-3">
      <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800">
        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed whitespace-pre-line">
          {description}
        </p>
      </div>
      {
        link && (
          <a href={link} target="_blank" rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-primary-500 hover:text-primary-600 dark:hover:text-primary-400 transition-all duration-200 hover:gap-2">
            {knowMore}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</div>